{
  "name": "@caption-cam/desktop",
  "version": "1.0.0",
  "private": true,
  "author": "Creator Enji",
  "repository": {
    "type": "git",
    "url": "https://github.com/Negi97Mohit/caption-cam"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && electron-builder",
    "release": "tsc && electron-builder --publish always"
  },
  "dependencies": {
    "async": "^3.2.6",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-fetch": "^2.7.0",
    "node-media-server": "^2.6.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.0.0"
  },
  "build": {
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "../../build/icon.ico",
      "publisherName": "Creator Enji"
    },
    "nsis": {
      "artifactName": "GAKI - House of Video Creation Setup.${ext}"
    },
    "mac": {
      "entitlements": "../../build/entitlements.mac.plist",
      "target": "dmg",
      "icon": "../../build/icon.icns",
      "hardenedRuntime": true,
      "artifactName": "GAKI - House of Video Creation.${ext}"
    },
    "linux": {
      "target": "AppImage"
    },
    "productName": "GAKI - House of Video Creation",
    "files": [
      "dist/**/*",
      "package.json",
      "../web/dist/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "appId": "com.captioncam.studio",
    "electronVersion": "30.5.1",
    "extraResources": [
      {
        "to": "web/dist",
        "from": "../web/dist"
      }
    ]
  }
}