# Platform API Keys (optional — app falls back to mock data if not set)

# YouTube Data API v3
# Get from https://console.cloud.google.com/ (enable YouTube Data API v3)
VITE_YOUTUBE_API_KEY=

# Twitch API
# Get from https://dev.twitch.tv/console
VITE_TWITCH_CLIENT_ID=
VITE_TWITCH_CLIENT_SECRET=

# Kick API (optional)
VITE_KICK_CLIENT_ID=
VITE_KICK_CLIENT_SECRET=

# Firebase — Required
# Get from https://console.firebase.google.com/ → Project Settings → General
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
