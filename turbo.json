{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "type-check"],
      "outputs": ["dist/**", ".next/**", "!-node_modules"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "@caption-cam/desktop#build": {
      "dependsOn": ["@caption-cam/web#build", "^build"],
      "outputs": ["dist/**", "release/**"]
    },
    "@caption-cam/desktop#release": {
      "dependsOn": ["@caption-cam/web#build", "^build"],
      "outputs": ["dist/**", "release/**"],
      "env": ["GH_TOKEN", "GITHUB_TOKEN"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
