{
    "id": "omegle-sidebar-right",
    "name": "Sidebar Right",
    "description": "Videos in main area, chat in full-height right sidebar",
    "styleTags": [
        "omegle",
        "sidebar",
        "desktop"
    ],
    "canvasAspectRatio": "16:9",
    "background": {
        "blankCanvasColor": "#0F0F0F",
        "backgroundEffect": "none"
    },
    "layout": {
        "strangerVideo": {
            "position": {
                "x": 0,
                "y": 0
            },
            "size": {
                "width": 75,
                "height": 60
            },
            "zIndex": 1
        },
        "localVideo": {
            "position": {
                "x": 0,
                "y": 60
            },
            "size": {
                "width": 75,
                "height": 40
            },
            "zIndex": 1,
            "mirror": true
        },
        "chatBox": {
            "position": {
                "x": 75,
                "y": 0
            },
            "size": {
                "width": 25,
                "height": 100
            },
            "zIndex": 200,
            "style": {
                "backgroundColor": "rgba(20, 20, 23, 1)",
                "borderLeft": "1px solid rgba(255, 255, 255, 0.1)"
            }
        },
        "controls": {
            "position": "top-left",
            "zIndex": 200
        }
    },
    "effects": {
        "videoFilter": "none",
        "transition": "fade",
        "transitionDuration": 300
    },
    "typography": {
        "fontFamily": "Inter",
        "fontSize": 14,
        "color": "#FFFFFF"
    }
}