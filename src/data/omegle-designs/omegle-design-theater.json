{
    "id": "omegle-theater",
    "name": "Theater Mode",
    "description": "Cinematic 16:9 letterboxed experience",
    "styleTags": [
        "omegle",
        "cinematic",
        "widescreen",
        "elegant"
    ],
    "canvasAspectRatio": "16:9",
    "background": {
        "blankCanvasColor": "#0A0A0A",
        "backgroundEffect": "none"
    },
    "layout": {
        "strangerVideo": {
            "position": {
                "x": 10,
                "y": 12.5
            },
            "size": {
                "width": 80,
                "height": 75
            },
            "zIndex": 1,
            "aspectRatio": "16:9",
            "objectFit": "contain"
        },
        "localVideo": {
            "position": {
                "x": 5,
                "y": 80
            },
            "size": {
                "width": 15,
                "height": 16
            },
            "zIndex": 3,
            "mirror": true,
            "shape": "rounded",
            "borderRadius": 12,
            "border": {
                "color": "rgba(255, 255, 255, 0.15)",
                "width": 1
            }
        },
        "chatBox": {
            "position": {
                "x": 70,
                "y": 88
            },
            "size": {
                "width": 25,
                "height": 10
            },
            "zIndex": 2,
            "collapsed": true,
            "expandOnInteraction": true,
            "expandedSize": {
                "width": 35,
                "height": 40
            },
            "style": {
                "backgroundColor": "rgba(10, 10, 10, 0.92)",
                "backdropFilter": "blur(15px)",
                "border": "1px solid rgba(255, 255, 255, 0.06)",
                "borderRadius": "16px"
            }
        },
        "controls": {
            "position": "top-right",
            "zIndex": 10,
            "autoHide": true,
            "autoHideDelay": 3000,
            "style": {
                "backgroundColor": "rgba(0, 0, 0, 0.6)",
                "backdropFilter": "blur(8px)",
                "padding": "6px",
                "borderRadius": "10px",
                "margin": "10px"
            }
        }
    },
    "effects": {
        "videoFilter": "contrast(1.08) saturate(1.1)",
        "letterbox": true,
        "letterboxColor": "#000000",
        "transition": "fade",
        "transitionDuration": 500
    },
    "typography": {
        "fontFamily": "Inter",
        "fontSize": 12,
        "color": "#F0F0F0",
        "lineHeight": 1.5
    }
}