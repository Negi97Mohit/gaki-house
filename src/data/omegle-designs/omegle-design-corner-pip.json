{
    "id": "omegle-corner-pip",
    "name": "Corner PiP",
    "description": "Fullscreen stranger with small local video in corner",
    "styleTags": ["omegle", "pip", "immersive", "minimal"],
    "canvasAspectRatio": "16:9",
    "background": {
        "blankCanvasColor": "#000000",
        "backgroundEffect": "none"
    },
    "layout": {
        "strangerVideo": {
            "position": { "x": 0, "y": 0 },
            "size": { "width": 100, "height": 100 },
            "zIndex": 1
        },
        "localVideo": {
            "position": { "x": 75, "y": 70 },
            "size": { "width": 22, "height": 26 },
            "zIndex": 10,
            "mirror": true,
            "shape": "rounded",
            "borderRadius": 16,
            "border": { "color": "rgba(255,255,255,0.2)", "width": 2 },
            "shadow": { "blur": 20, "color": "rgba(0,0,0,0.5)" }
        },
        "chatBox": {
            "position": { "x": 2, "y": 60 },
            "size": { "width": 35, "height": 38 },
            "zIndex": 200,
            "floating": true
        },
        "controls": {
            "position": "bottom-center",
            "zIndex": 200
        }
    },
    "effects": {
        "videoFilter": "brightness(1.02)",
        "transition": "fade",
        "transitionDuration": 250
    },
    "typography": {
        "fontFamily": "Inter",
        "fontSize": 14,
        "color": "#FFFFFF"
    }
}
