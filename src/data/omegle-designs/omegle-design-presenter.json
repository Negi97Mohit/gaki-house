{
    "id": "omegle-presenter",
    "name": "Presenter",
    "description": "Presentation style with large stranger and bottom bar",
    "styleTags": ["omegle", "presenter", "professional", "clean"],
    "canvasAspectRatio": "16:9",
    "background": {
        "blankCanvasColor": "#0f0f0f",
        "backgroundEffect": "none"
    },
    "layout": {
        "strangerVideo": {
            "position": { "x": 2, "y": 2 },
            "size": { "width": 96, "height": 72 },
            "zIndex": 1,
            "shape": "rounded",
            "borderRadius": 16
        },
        "localVideo": {
            "position": { "x": 2, "y": 76 },
            "size": { "width": 20, "height": 22 },
            "zIndex": 10,
            "mirror": true,
            "shape": "rounded",
            "borderRadius": 12,
            "border": { "color": "rgba(255,255,255,0.1)", "width": 1 }
        },
        "chatBox": {
            "position": { "x": 24, "y": 76 },
            "size": { "width": 74, "height": 22 },
            "zIndex": 200,
            "floating": false
        },
        "controls": {
            "position": "top-right",
            "zIndex": 200
        }
    },
    "effects": {
        "videoFilter": "brightness(1.02)",
        "transition": "fade",
        "transitionDuration": 250
    },
    "typography": {
        "fontFamily": "Inter",
        "fontSize": 13,
        "color": "#FFFFFF"
    }
}
