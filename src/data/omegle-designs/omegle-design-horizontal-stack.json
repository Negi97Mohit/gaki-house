{
    "id": "omegle-horizontal-stack",
    "name": "Horizontal Stack",
    "description": "Videos stacked horizontally with chat on the side",
    "styleTags": ["omegle", "horizontal", "widescreen", "modern"],
    "canvasAspectRatio": "16:9",
    "background": {
        "blankCanvasColor": "#0A0A0A",
        "backgroundEffect": "none"
    },
    "layout": {
        "strangerVideo": {
            "position": { "x": 0, "y": 10 },
            "size": { "width": 40, "height": 80 },
            "zIndex": 1,
            "shape": "rounded",
            "borderRadius": 12
        },
        "localVideo": {
            "position": { "x": 42, "y": 10 },
            "size": { "width": 30, "height": 80 },
            "zIndex": 1,
            "mirror": true,
            "shape": "rounded",
            "borderRadius": 12
        },
        "chatBox": {
            "position": { "x": 74, "y": 5 },
            "size": { "width": 24, "height": 90 },
            "zIndex": 200,
            "floating": true
        },
        "controls": {
            "position": "bottom-center",
            "zIndex": 200
        }
    },
    "effects": {
        "videoFilter": "none",
        "transition": "fade",
        "transitionDuration": 300
    },
    "typography": {
        "fontFamily": "Inter",
        "fontSize": 13,
        "color": "#FFFFFF"
    }
}
